<!DOCTYPE html>
<html>

  <head>
    <meta charset="UTF-8">
    <title><%=titulo%></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>

  <body>

    <h1>Identifique-se</h1>

    <form action="/login" method="post">

      <label>Usuário</label>
      <input type="text" id=" edtUsuario" name="edtUsuario"/>
      <br/>

      <label>Senha</label>
      <input type="password" id="edtSenha" name="edtSenha"/>
      <br/>

      <input type="submit" value="Entrar"/>
      <input type="reset" value="Limpar"/>

    </form>

  </body>

</html>
